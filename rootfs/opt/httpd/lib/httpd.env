APACHE_BIN_DIR=/usr/sbin
APACHE_CONF_FILE=/opt/httpd/etc/httpd.conf
APACHE_LISTEN_PORT=8080
APACHE_SERVER_ROOT=/var/www
APACHE_DOCUMENT_ROOT=/app
APACHE_SERVERNAME=localhost
APACHE_SERVERADMIN=root@localhost
APACHE_ENABLE_ACCESS_LOG=false
APACHE_LOGLEVEL=warn
APACHE_MOD_REWRITE=false
APACHE_MOD_MPM_PREFORK=false
APACHE_MOD_MPM_EVENT=true
APACHE_MOD_CGI=false
APACHE_MOD_STATUS=false
APACHE_MOD_NEGOTIATION=false
APACHE_MOD_DEFLATE=false
APACHE_MOD_AUTOINDEX=false
APACHE_MOD_MIME=true
APACHE_MOD_DAV=false
APACHE_MOD_PROXY=false
APACHE_MOD_SSL=false
APACHE_SSL_HONOR_CIPHER_ORDER=on
APACHE_SSL_LISTEN_SSL_PORT=443
APACHE_SSL_CIPHER_SUITE=TLSv1.2+AESGCM+ECDHE
APACHE_SSL_PROXY_CIPHER_SUITE=TLSv1.2+AESGCM+ECDHE
APACHE_SSL_PROTOCOL="TLSv1.2 TLSv1.3"
APACHE_SSL_PROXY_PROTOCOL="TLSv1.2 TLSv1.3"
APACHE_SSL_SESSION_CACHE_TIMEOUT=300
APACHE_SSL_USE_STAPLING=off
APACHE_SSL_STAPLING_STANDARD_CACHE_TIMEOUT=3600
APACHE_SSL_STAPLING_ERROR_CACHE_TIMEOUT=600
APACHE_SSL_CERTIFICATE_FILE=/opt/httpd/etc/ssl/selfsigned.crt
APACHE_SSL_CERTIFICATE_KEY_FILE=/opt/httpd/etc/ssl/selfsigned.key
APACHE_SSL_ENABLE_HSTS=false
